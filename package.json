{
  "name": "job-sync",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm run tauri dev",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:build:portable": "node scripts/build-portable.mjs",
    "tauri:build:portable:only": "node scripts/build-portable.mjs --skip-build",
    "tauri:build:release": "npm run tauri:build && npm run tauri:build:portable:only",
    "build:worker": "npm -w @job-sync/boss-crawler-worker run build",
    "start:worker": "npm -w @job-sync/boss-crawler-worker run start",
    "stage:worker:runtime:win": "node scripts/stage-worker-runtime.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-vue-next": "^0.576.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
