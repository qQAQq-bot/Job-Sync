{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "job-sync",
  "version": "0.1.0",
  "identifier": "com.administrator.job-sync",
  "build": {
    "beforeDevCommand": "npm run build:worker && npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build:worker:exe:win && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "job-sync",
        "width": 1200,
        "minWidth": 1100,
        "height": 800,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["bin/boss-crawler-worker"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
